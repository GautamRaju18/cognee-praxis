# Copy this file to .env and fill in your Gemini API key.
# Get a key at https://aistudio.google.com/apikey

# LLM configuration (used for entity/relationship extraction)
LLM_PROVIDER="gemini"
LLM_MODEL="gemini/gemini-flash-latest"
LLM_API_KEY="your_gemini_api_key"

# Embeddings configuration (Gemini also handles embeddings)
EMBEDDING_PROVIDER="gemini"
EMBEDDING_MODEL="gemini/gemini-embedding-001"
EMBEDDING_API_KEY="your_gemini_api_key"
