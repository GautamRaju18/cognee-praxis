# Copy this file to .env and fill in your provider credentials.
# Cognee reads LLM_*/EMBEDDING_* natively (litellm underneath), so switching
# providers is only an env change — no code changes.

# --- Gemini (default) --------------------------------------------------------
LLM_PROVIDER="gemini"
# Pin a model rather than "-latest": Gemini free-tier daily quotas are per-model
# and the latest alias may have a much smaller bucket (e.g. 20 req/day).
LLM_MODEL="gemini/gemini-2.5-flash"
LLM_API_KEY="your_gemini_api_key"
EMBEDDING_PROVIDER="gemini"
EMBEDDING_MODEL="gemini/gemini-embedding-001"
EMBEDDING_API_KEY="your_gemini_api_key"

# --- OpenAI ------------------------------------------------------------------
# LLM_PROVIDER="openai"
# LLM_MODEL="gpt-4o-mini"
# LLM_API_KEY="sk-..."
# EMBEDDING_PROVIDER="openai"
# EMBEDDING_MODEL="text-embedding-3-small"
# EMBEDDING_API_KEY="sk-..."

# --- Local Ollama ------------------------------------------------------------
# LLM_PROVIDER="ollama"
# LLM_MODEL="ollama/llama3.1"
# LLM_ENDPOINT="http://localhost:11434/v1"
# LLM_API_KEY="ollama"
# EMBEDDING_PROVIDER="ollama"
# EMBEDDING_MODEL="ollama/nomic-embed-text"
# EMBEDDING_ENDPOINT="http://localhost:11434/api/embed"
# EMBEDDING_DIMENSIONS="768"

# --- Rate limiting (recommended for free-tier API keys) -----------------------
# Cognee's client-side limiter; keeps bursts under your provider's RPM quota.
LLM_RATE_LIMIT_ENABLED="true"
LLM_RATE_LIMIT_REQUESTS="8"
LLM_RATE_LIMIT_INTERVAL="60"
EMBEDDING_RATE_LIMIT_ENABLED="true"
EMBEDDING_RATE_LIMIT_REQUESTS="50"
EMBEDDING_RATE_LIMIT_INTERVAL="60"

# --- Praxis ------------------------------------------------------------------
# Cognee dataset name for the company brain (tests use their own):
# PRAXIS_DATASET="praxis"
# PRAXIS_DATABASE_URL="sqlite+aiosqlite:///./praxis.db"
# Single-user local app; cognee 1.x defaults this to true (multi-tenant):
ENABLE_BACKEND_ACCESS_CONTROL="false"
